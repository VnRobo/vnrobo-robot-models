<!-- VNR-WH1 — VnRobo Wheeled Humanoid 1
     Version: 1.0.0-clean
     DOF: 19 (3 wheels + 7L + 7R + 2 grippers)

     v1.0 — clean silhouette (supersedes v0.9):
       - Removed torso_chest + torso_accent (chunky matte-black pedestal +
         orange stripe above the waist ring — looked like a bolt-on chest plate).
       - Hid ALL native OpenArm body_link0 meshes (body_v0..v5 → group=4). They
         carried a triangular shoulder bracket and bolt-hole fascia that read
         as "extra steel plates" on a clean humanoid design.
       - torso_column extended down to world z=0.33 so it rises directly from
         the orange brand band — no intermediate pedestal, just a slim 0.10 ×
         0.08 m pillar from base to shoulders.
       - head_cam, torso_band, arms unchanged — proven from v0.9.

     Stack, world z:
       0.00–0.30   wheeled base (cylinder r=0.30)
       0.30–0.33   waist collar disc  (r=0.205)
       0.33–0.35   waist accent ring  (r=0.215, orange — brand band)
       0.33–1.25   torso_column       (0.10 × 0.08 × 0.92 slim pillar)
       1.22–1.24   torso_band         (orange accent at shoulder line)
       1.25        shoulder (arms emerge from body_link0 at local z=0.698)
-->
<mujoco model="vnr_wh1">

  <compiler angle="radian" meshdir="assets/openarm" inertiafromgeom="auto"/>

  <visual>
    <global offwidth="1920" offheight="1080"/>
  </visual>

  <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>

  <!-- =============================================================== -->
  <!-- DEFAULTS                                                         -->
  <!-- =============================================================== -->
  <default>
    <geom condim="4" friction="1.0 0.005 0.0001" solimp="0.9 0.95 0.001" solref="0.02 1"/>

    <default class="wheel">
      <joint type="hinge" damping="0.3" armature="0.005" limited="false"/>
      <velocity gear="1" ctrlrange="-15 15"/>
    </default>

    <!-- OpenArm joint physics from bimanual.xml -->
    <default class="motor_DM8009">
      <joint frictionloss="0.1" damping="0.4" limited="true" type="hinge"/>
    </default>
    <default class="motor_DM4340">
      <joint frictionloss="0.1" damping="0.4" limited="true" type="hinge"/>
    </default>
    <default class="motor_DM4310">
      <joint frictionloss="0.1" damping="0.4" limited="true" type="hinge"/>
    </default>
    <default class="motor_finger">
      <joint limited="true" type="slide" damping="2" stiffness="0.5"/>
    </default>

    <!-- Position actuator classes for arm joints -->
    <default class="arm_DM8009">
      <position kp="120" kv="12" forcelimited="true" forcerange="-40 40"/>
    </default>
    <default class="arm_DM4340">
      <position kp="80" kv="8" forcelimited="true" forcerange="-27 27"/>
    </default>
    <default class="arm_DM4310">
      <position kp="50" kv="5" forcelimited="true" forcerange="-7 7"/>
    </default>
    <default class="arm_finger">
      <position kp="100" kv="5" ctrlrange="0 0.044" forcelimited="true" forcerange="-333 333"/>
    </default>

    <!-- Geom display classes (collision disabled for stability) -->
    <default class="visual">
      <geom contype="0" conaffinity="0" group="2" density="0"/>
    </default>
    <default class="collision">
      <geom contype="0" conaffinity="0" group="3" density="0"/>
    </default>
  </default>

  <!-- =============================================================== -->
  <!-- ASSETS                                                           -->
  <!-- =============================================================== -->
  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.8 0.8 0.8" rgb2="0.6 0.6 0.6"
             width="512" height="512"/>
    <material name="floor_mat"        texture="grid" texrepeat="4 4" reflectance="0.2"/>
    <material name="dark_mat"         rgba="0.20 0.20 0.22 1" reflectance="0.08"/>
    <material name="body_mat"         rgba="0.95 0.62 0.10 1"/>
    <material name="matte_black"      rgba="0.15 0.15 0.17 1" reflectance="0.05" shininess="0.3"/>
    <material name="metal_silver"     rgba="0.796 0.796 0.796 1" reflectance="1.0"  shininess="1.0"/>
    <material name="default_material" rgba="0.7 0.7 0.7 1"/>

    <!-- body_link0 back-plate (kept for kinematic compat; visuals hidden in v0.7) -->
    <mesh name="body_col"  file="collision/body/body_link0.stl" scale="0.001 0.001 0.001"/>
    <mesh name="body_v0"   file="visual/body/body_link0_0.obj"  scale="0.001 0.001 0.001"/>
    <mesh name="body_v1"   file="visual/body/body_link0_1.obj"  scale="0.001 0.001 0.001"/>
    <mesh name="body_v2"   file="visual/body/body_link0_2.obj"  scale="0.001 0.001 0.001"/>
    <mesh name="body_v3"   file="visual/body/body_link0_3.obj"  scale="0.001 0.001 0.001"/>
    <mesh name="body_v4"   file="visual/body/body_link0_4.obj"  scale="0.001 0.001 0.001"/>
    <mesh name="body_v5"   file="visual/body/body_link0_5.obj"  scale="0.001 0.001 0.001"/>

    <!-- Arm collision meshes (right and left-mirror) -->
    <mesh name="link0_col"   file="collision/arm/link0.stl" scale="0.001  0.001 0.001"/>
    <mesh name="link0_col_l" file="collision/arm/link0.stl" scale="0.001 -0.001 0.001"/>
    <mesh name="link1_col"   file="collision/arm/link1.stl" scale="0.001  0.001 0.001"/>
    <mesh name="link1_col_l" file="collision/arm/link1.stl" scale="0.001 -0.001 0.001"/>
    <mesh name="link2_col"   file="collision/arm/link2.stl" scale="0.001  0.001 0.001"/>
    <mesh name="link2_col_l" file="collision/arm/link2.stl" scale="0.001 -0.001 0.001"/>
    <mesh name="link3_col"   file="collision/arm/link3.stl" scale="0.001  0.001 0.001"/>
    <mesh name="link3_col_l" file="collision/arm/link3.stl" scale="0.001 -0.001 0.001"/>
    <mesh name="link4_col"   file="collision/arm/link4.stl" scale="0.001  0.001 0.001"/>
    <mesh name="link5_col"   file="collision/arm/link5.stl" scale="0.001  0.001 0.001"/>
    <mesh name="link5_col_l" file="collision/arm/link5.stl" scale="0.001 -0.001 0.001"/>
    <mesh name="link6_col"   file="collision/arm/link6.stl" scale="0.001  0.001 0.001"/>
    <mesh name="link6_col_l" file="collision/arm/link6.stl" scale="0.001 -0.001 0.001"/>
    <mesh name="link7_col"   file="collision/arm/link7.stl" scale="0.001  0.001 0.001"/>
    <mesh name="link7_col_l" file="collision/arm/link7.stl" scale="0.001 -0.001 0.001"/>
    <mesh name="hand_col"     file="collision/gripper/hand.stl"    scale="0.001 0.001 0.001"/>
    <mesh name="finger_col"   file="collision/gripper/finger.stl"  scale="0.001  0.001 0.001"/>
    <mesh name="finger_col_l" file="collision/gripper/finger.stl"  scale="0.001 -0.001 0.001"/>

    <!-- Arm visual meshes -->
    <mesh name="link0_v0"   file="visual/arm/link0_0.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link0_v1"   file="visual/arm/link0_1.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link1_v0"   file="visual/arm/link1_0.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link1_v2"   file="visual/arm/link1_2.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link1_v3"   file="visual/arm/link1_3.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link2_v0"   file="visual/arm/link2_0.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link2_v1"   file="visual/arm/link2_1.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link2_v2"   file="visual/arm/link2_2.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link3_v0"   file="visual/arm/link3_0.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link3_v1"   file="visual/arm/link3_1.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link3_v2"   file="visual/arm/link3_2.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link4_v0"   file="visual/arm/link4_0.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link4_v1"   file="visual/arm/link4_1.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link4_v2"   file="visual/arm/link4_2.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link5_v0"   file="visual/arm/link5_0.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link5_v1"   file="visual/arm/link5_1.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link5_v2"   file="visual/arm/link5_2.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link6_v0"   file="visual/arm/link6_0.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link6_v1"   file="visual/arm/link6_1.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link6_v0_l" file="visual/arm/link6_0.obj" scale="0.001 -0.001 0.001"/>
    <mesh name="link6_v1_l" file="visual/arm/link6_1.obj" scale="0.001 -0.001 0.001"/>
    <mesh name="link7_v0"   file="visual/arm/link7_0.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link7_v1"   file="visual/arm/link7_1.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link7_v0_l" file="visual/arm/link7_0.obj" scale="0.001 -0.001 0.001"/>
    <mesh name="link7_v1_l" file="visual/arm/link7_1.obj" scale="0.001 -0.001 0.001"/>
    <mesh name="hand_v0"    file="visual/gripper/hand_0.obj"    scale="0.001 0.001 0.001"/>
    <mesh name="hand_v1"    file="visual/gripper/hand_1.obj"    scale="0.001 0.001 0.001"/>
    <mesh name="finger_v0"   file="visual/gripper/finger_0.obj" scale="0.001  0.001 0.001"/>
    <mesh name="finger_v1"   file="visual/gripper/finger_1.obj" scale="0.001  0.001 0.001"/>
    <mesh name="finger_v0_l" file="visual/gripper/finger_0.obj" scale="0.001 -0.001 0.001"/>
    <mesh name="finger_v1_l" file="visual/gripper/finger_1.obj" scale="0.001 -0.001 0.001"/>
  </asset>

  <!-- =============================================================== -->
  <!-- WORLD                                                            -->
  <!-- =============================================================== -->
  <worldbody>
    <light name="sky"   pos="0 0 6"   dir="0 0 -1"    ambient="0.25 0.25 0.25" diffuse="1.0 1.0 1.0" specular="0.3 0.3 0.3" castshadow="false"/>
    <light name="fill"  pos="3 -3 4"  dir="-1 1 -1"   ambient="0.10 0.10 0.10" diffuse="0.5 0.5 0.6" specular="0 0 0"         castshadow="false"/>
    <light name="front" pos="0 6 3"   dir="0 -1 -0.4" ambient="0.10 0.10 0.10" diffuse="0.6 0.6 0.6" specular="0.15 0.15 0.15" castshadow="false"/>
    <geom name="floor" type="plane" size="8 8 0.1" material="floor_mat" condim="3"/>

    <!-- ======================== WHEELED BASE ========================
         Omnidirectional 3-wheel platform: cylinder r=0.30 h=0.20
         Base extent world z=0.10..0.30; wheels at z≈0.02 (floor contact)
    -->
    <body name="base" pos="0 0 0.20">
      <freejoint name="root"/>
      <geom name="base_geom" type="cylinder" size="0.30 0.10" material="dark_mat" mass="20"/>
      <site name="imu" pos="0 0 0" size="0.01"/>

      <!-- 3× omnidirectional wheels -->
      <body name="wheel_f"  pos="0 0.22 -0.12">
        <joint name="wheel_f" class="wheel" axis="1 0 0"/>
        <geom type="cylinder" size="0.080 0.040" zaxis="1 0 0" material="dark_mat" mass="0.8" friction="2 0.01 0.001"/>
        <geom type="cylinder" size="0.055 0.039" zaxis="1 0 0" material="body_mat" mass="0"/>
      </body>
      <body name="wheel_bl" pos="-0.19 -0.11 -0.12">
        <joint name="wheel_bl" class="wheel" axis="-0.5 0.866 0"/>
        <geom type="cylinder" size="0.080 0.040" zaxis="-0.5 0.866 0" material="dark_mat" mass="0.8" friction="2 0.01 0.001"/>
        <geom type="cylinder" size="0.055 0.039" zaxis="-0.5 0.866 0" material="body_mat" mass="0"/>
      </body>
      <body name="wheel_br" pos="0.19 -0.11 -0.12">
        <joint name="wheel_br" class="wheel" axis="0.5 0.866 0"/>
        <geom type="cylinder" size="0.080 0.040" zaxis="0.5 0.866 0" material="dark_mat" mass="0.8" friction="2 0.01 0.001"/>
        <geom type="cylinder" size="0.055 0.039" zaxis="0.5 0.866 0" material="body_mat" mass="0"/>
      </body>

      <!-- ==================== MOUNT CAP v1.0 ====================
           Minimal adapter: base top → torso_column base. v0.9 had a chunky
           torso_chest box + accent stripe that made the junction look like a
           bolt-on steel pedestal. v1.0 drops both — torso_column (inside
           openarm_body_link0) runs straight from the orange brand ring all
           the way up to the shoulders. Cleaner, humanoid neckline.
             1. waist_collar  → short wide dark disc crowning the base
             2. waist_accent  → orange brand ring (top of adapter)
      -->
      <geom name="waist_collar" type="cylinder" size="0.205 0.015"
            pos="0 0 0.115" material="dark_mat"/>
      <geom name="waist_accent" type="cylinder" size="0.215 0.010"
            pos="0 0 0.140" material="body_mat"/>

      <!-- ================ OPENARM BIMANUAL ASSEMBLY ================
           body_link0 = kinematic parent of both arms (OpenArm verbatim chains).
           Mounted to torso top with 90°Z rotation so arm chains extend ±world_x.
           body_link0 origin at world z = 0.20 + 0.35 = 0.55.
           Arm link0 lands at local (±0.031y, +0.698z) → world (∓0.031x, 0, 1.248).
           VISIBLE body meshes (v1, v4, v5): native OpenArm shoulder bridge plate
             and fascia — doubles as the camera bay for head optics.
           HIDDEN (group=4): v0 (datum marker), v2 (small bracket), v3 (internal
             backbone tube, replaced by our torso_chest box).
      -->
      <body name="openarm_body_link0" pos="0 0 0.35" quat="0.7071068 0 0 0.7071068">
        <inertial pos="0.0 0.0 0.0" quat="1.0 0.0 0.0 0.0" mass="13.89"
                  diaginertia="1.653 1.653 0.051"/>
        <geom type="mesh" mesh="body_col" class="collision"/>
        <!-- v1.0: all native OpenArm body_link0 visual meshes are hidden
             (group=4). They carried the triangular shoulder bracket, bolt-hole
             fascia, and internal backbone — all superseded by our clean
             torso_column + head_cam primitives below.                     -->
        <geom type="mesh" material="matte_black"  mesh="body_v0" class="visual" group="4"/>
        <geom type="mesh" material="matte_black"  mesh="body_v1" class="visual" group="4"/>
        <geom type="mesh" material="matte_black"  mesh="body_v2" class="visual" group="4"/>
        <geom type="mesh" material="matte_black"  mesh="body_v3" class="visual" group="4"/>
        <geom type="mesh" material="metal_silver" mesh="body_v4" class="visual" group="4"/>
        <geom type="mesh" material="matte_black"  mesh="body_v5" class="visual" group="4"/>

        <!-- v1.0 — torso_column: single slim pillar, base to shoulders.
             Extended DOWN to world z=0.35 (touches waist_accent ring) so there
             is no intermediate chest pedestal — just the clean column rising
             directly from the orange brand band. Native body_link0 meshes are
             all hidden (group=4) so the silhouette is purely our primitives.
             World footprint 0.10 × 0.08 m × 0.92 m tall.
             Local frame has a 90°Z quat so local x → world y, local y → world x.
               x half=0.040 → world y half (depth)  = 0.040 (total 0.08)
               y half=0.050 → world x half (width)  = 0.050 (total 0.10)
               z half=0.460 →             height    = 0.920
             Local pos z=0.240 → world z center=0.79, spans world z=0.33..1.25 -->
        <geom name="torso_column" type="box" size="0.040 0.050 0.460"
              pos="0 0 0.240" material="matte_black"/>
        <geom name="torso_band"   type="box" size="0.045 0.055 0.012"
              pos="0 0 0.680" material="body_mat"/>

        <!-- v0.9 FIX ② — head_cam moved from body_v1 fascia (local +y, faced
             world -x = arm-span axis) to body_v4 fascia (local -x, faces
             world -y). That is the robot's actual front (perpendicular to
             the arm-span axis).
             Housing cylinder axis rotated 90° around local y so its barrel
             points along local x = world y.                                -->
        <geom name="head_cam_housing" type="cylinder" size="0.020 0.015"
              pos="-0.115 0 0.020" quat="0.7071068 0 0.7071068 0"
              material="matte_black"/>
        <geom name="head_cam_lens"    type="cylinder" size="0.010 0.004"
              pos="-0.132 0 0.020" quat="0.7071068 0 0.7071068 0"
              material="metal_silver"/>
        <site name="head_cam"  pos="-0.140 0 0.020" size="0.006" rgba="0 1 1 0.8"/>

        <!-- =================== LEFT ARM (verbatim from openarm_bimanual.xml) =================== -->
        <body name="openarm_left_link0" pos="0.0 0.031 0.698"
              quat="0.7071054825112363 -0.7071080798594735 0.0 0.0">
          <inertial pos="-0.0009483362816297526 0.0001580207020448382 0.03076860287587199"
                    quat="1.0 0.0 0.0 0.0" mass="1.1432284943239561"
                    diaginertia="0.001128 0.000962 0.00147"/>
          <geom type="mesh" mesh="link0_col_l" class="collision"/>
          <geom type="mesh" material="metal_silver" mesh="link0_v0" class="visual"/>
          <geom type="mesh" material="matte_black"  mesh="link0_v1" class="visual"/>

          <body name="openarm_left_link1" pos="0.0 0.0 0.0625" quat="1.0 0.0 0.0 0.0">
            <joint name="openarm_left_joint1" class="motor_DM8009"
                   range="-3.490659 1.3962629999999998" axis="0 0 1"/>
            <inertial pos="0.0011467657911800769 3.319987657026362e-05 0.05395284380736254"
                      quat="1.0 0.0 0.0 0.0" mass="1.1416684646202298"
                      diaginertia="0.001567 0.001273 0.001016"/>
            <geom pos="-0.0 0.0 -0.0625" type="mesh" mesh="link1_col_l" class="collision"/>
            <geom pos="-0.0 0.0 -0.0625" type="mesh" material="matte_black" mesh="link1_v0" class="visual"/>
            <geom pos="-0.0 0.0 -0.0625" type="mesh" material="matte_black" mesh="link1_v2" class="visual"/>
            <geom pos="-0.0 0.0 -0.0625" type="mesh" material="matte_black" mesh="link1_v3" class="visual"/>

            <body name="openarm_left_link2" pos="-0.0301 0.0 0.06"
                  quat="0.7071067811882787 -0.7071067811848163 0.0 0.0">
              <joint name="openarm_left_joint2" class="motor_DM8009"
                     range="-3.3161253267948965 0.17453267320510335" axis="-1 0 0"/>
              <inertial pos="0.00839629182351943 -2.0145102027597523e-08 0.03256649300522363"
                        quat="1.0 0.0 0.0 0.0" mass="0.2775092746011571"
                        diaginertia="0.000359 0.000376 0.000232"/>
              <geom pos="0.0301 0.0 -0.1225" type="mesh" mesh="link2_col_l" class="collision"/>
              <geom pos="0.0301 0.0 -0.1225" type="mesh" material="matte_black" mesh="link2_v0" class="visual"/>
              <geom pos="0.0301 0.0 -0.1225" type="mesh" material="matte_black" mesh="link2_v1" class="visual"/>
              <geom pos="0.0301 0.0 -0.1225" type="mesh" material="matte_black" mesh="link2_v2" class="visual"/>

              <body name="openarm_left_link3" pos="0.0301 0.0 0.06625" quat="1.0 0.0 0.0 0.0">
                <joint name="openarm_left_joint3" class="motor_DM4340"
                       range="-1.570796 1.570796" axis="0 0 1"/>
                <inertial pos="-0.002104752099628911 0.0005549085042607548 0.08847470545721961"
                          quat="1.0 0.0 0.0 0.0" mass="1.073863338202347"
                          diaginertia="0.004372 0.004319 0.000661"/>
                <geom pos="-0.0 -0.0 -0.18875" type="mesh" mesh="link3_col_l" class="collision"/>
                <geom pos="-0.0 -0.0 -0.18875" type="mesh" material="matte_black"  mesh="link3_v0" class="visual"/>
                <geom pos="-0.0 -0.0 -0.18875" type="mesh" material="matte_black"  mesh="link3_v1" class="visual"/>
                <geom pos="-0.0 -0.0 -0.18875" type="mesh" material="metal_silver" mesh="link3_v2" class="visual"/>

                <body name="openarm_left_link4" pos="-0.0 0.0315 0.15375" quat="1.0 0.0 0.0 0.0">
                  <joint name="openarm_left_joint4" class="motor_DM4340"
                         range="0.0 2.443461" axis="0 1 0"/>
                  <inertial pos="-0.0029006831074562967 -0.03030575826634669 0.06339637422196209"
                            quat="1.0 0.0 0.0 0.0" mass="0.6348534566833373"
                            diaginertia="0.001577 0.001346 0.001104"/>
                  <geom pos="0.0 -0.0315 -0.3425" type="mesh" mesh="link4_col" class="collision"/>
                  <geom pos="0.0 -0.0315 -0.3425" type="mesh" material="matte_black"  mesh="link4_v0" class="visual"/>
                  <geom pos="0.0 -0.0315 -0.3425" type="mesh" material="metal_silver" mesh="link4_v1" class="visual"/>
                  <geom pos="0.0 -0.0315 -0.3425" type="mesh" material="matte_black"  mesh="link4_v2" class="visual"/>

                  <body name="openarm_left_link5" pos="0.0 -0.0315 0.0955" quat="1.0 0.0 0.0 0.0">
                    <joint name="openarm_left_joint5" class="motor_DM4310"
                           range="-1.570796 1.570796" axis="0 0 1"/>
                    <inertial pos="-0.003049665024221911 0.0008866902457326625 0.043079803024980934"
                              quat="1.0 0.0 0.0 0.0" mass="0.6156588026168502"
                              diaginertia="0.000423 0.000445 0.000324"/>
                    <geom pos="-0.0 -0.0 -0.438" type="mesh" mesh="link5_col_l" class="collision"/>
                    <geom pos="-0.0 -0.0 -0.438" type="mesh" material="matte_black"  mesh="link5_v0" class="visual"/>
                    <geom pos="-0.0 -0.0 -0.438" type="mesh" material="metal_silver" mesh="link5_v1" class="visual"/>
                    <geom pos="-0.0 -0.0 -0.438" type="mesh" material="matte_black"  mesh="link5_v2" class="visual"/>

