<!-- VNR-WH1 — VnRobo Wheeled Humanoid 1
     Version: 0.4.0-mesh
     DOF: 21 (3 wheels + 2 head + 7L arm + 7R arm + 2 grippers)
     v0.4: Real OpenArm v1 mesh arms (enactic/openarm_mujoco)
       - Arm kinematic chain, inertials, joint limits copied verbatim
       - Right arm: 180° around X → hangs down from right shoulder
       - Left arm: 180° around Y → hangs down, mirrored
       - Base / torso / chest / head / wheels unchanged
-->
<mujoco model="vnr_wh1">

  <compiler angle="radian" meshdir="assets/openarm" inertiafromgeom="auto"/>

  <visual>
    <global offwidth="1920" offheight="1080"/>
  </visual>

  <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>

  <!-- =============================================================== -->
  <!-- DEFAULTS                                                         -->
  <!-- =============================================================== -->
  <default>
    <geom condim="4" friction="1.0 0.005 0.0001" solimp="0.9 0.95 0.001" solref="0.02 1"/>

    <!-- OpenArm joint physics (from openarm_mujoco v1) -->
    <default class="arm">
      <joint damping="0.25" frictionloss="0.02" limited="true"/>
      <position kp="80" kv="8"/>
    </default>

    <default class="gripper">
      <joint type="slide" damping="5" armature="0.001" limited="true" range="0.0 0.044"/>
      <position kp="200" kv="15" ctrlrange="0.0 0.044"/>
    </default>

    <default class="wheel">
      <joint type="hinge" damping="0.3" armature="0.005" limited="false"/>
      <velocity gear="1" ctrlrange="-15 15"/>
    </default>

    <default class="head">
      <joint type="hinge" damping="0.5" armature="0.005" limited="true"/>
      <position kp="50" kv="5"/>
    </default>

    <!-- OpenArm geom classes (collision disabled to prevent overlap with torso) -->
    <default class="arm_collision">
      <geom contype="0" conaffinity="0" group="3" density="0"/>
    </default>
    <default class="arm_visual">
      <geom contype="0" conaffinity="0" group="2" density="0"/>
    </default>
  </default>

