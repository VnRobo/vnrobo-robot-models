  </asset>

  <!-- =============================================================== -->
  <!-- WORLD                                                            -->
  <!-- =============================================================== -->
  <worldbody>
    <light name="sky"  pos="0 0 5"  dir="0 0 -1"  diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" castshadow="false"/>
    <light name="fill" pos="2 -2 3" dir="-1 1 -1" diffuse="0.3 0.3 0.4" specular="0 0 0"       castshadow="false"/>
    <geom name="floor" type="plane" size="8 8 0.1" material="floor_mat" condim="3"/>

    <!-- ======================== BASE PLATFORM ======================== -->
    <!-- base cylinder: r=0.28, h=0.20 → bottom at z=0.10, top at z=0.30 world -->
    <body name="base" pos="0 0 0.20">
      <freejoint name="root"/>
      <geom name="base_geom" type="cylinder" size="0.28 0.10" material="dark_mat" mass="22"/>
      <site name="base_front" pos="0 0.26 0.11" size="0.025" rgba="0.9 0.2 0.2 1"/>
      <site name="imu" pos="0 0 0" size="0.01"/>

      <!-- 3× omni wheels (bottom at z=0.10-0.08=0.02 ≈ floor) -->
      <body name="wheel_f"  pos="0 0.22 -0.12">
        <joint name="wheel_f" class="wheel" axis="1 0 0"/>
        <geom type="cylinder" size="0.080 0.040" zaxis="1 0 0" material="dark_mat" mass="0.8" friction="2 0.01 0.001"/>
        <geom type="cylinder" size="0.055 0.039" zaxis="1 0 0" material="body_mat" mass="0"/>
      </body>
      <body name="wheel_bl" pos="-0.19 -0.11 -0.12">
        <joint name="wheel_bl" class="wheel" axis="-0.5 0.866 0"/>
        <geom type="cylinder" size="0.080 0.040" zaxis="-0.5 0.866 0" material="dark_mat" mass="0.8" friction="2 0.01 0.001"/>
        <geom type="cylinder" size="0.055 0.039" zaxis="-0.5 0.866 0" material="body_mat" mass="0"/>
      </body>
      <body name="wheel_br" pos="0.19 -0.11 -0.12">
        <joint name="wheel_br" class="wheel" axis="0.5 0.866 0"/>
        <geom type="cylinder" size="0.080 0.040" zaxis="0.5 0.866 0" material="dark_mat" mass="0.8" friction="2 0.01 0.001"/>
        <geom type="cylinder" size="0.055 0.039" zaxis="0.5 0.866 0" material="body_mat" mass="0"/>
      </body>

      <!-- ======================== VERTICAL POLE ========================
           Slim dark cylinder: world z=0.30 (base top) → z=0.90
           pole body at z=0.10 above base → z=0.30 world
           geom centered at pole_body+0.30 → cylinder spans z=0.30..0.90 world -->
      <body name="pole" pos="0 0 0.10">
        <inertial pos="0 0 0.30" mass="4.0" diaginertia="0.10 0.10 0.002"/>
        <geom name="pole_geom" type="cylinder" size="0.035 0.30"
              pos="0 0 0.30" material="dark_mat"/>

        <!-- =================== OPENARM BIMANUAL ASSEMBLY =================
             body_link0 = shared back-plate with 6 visual mesh parts
             pos: 0.60 above pole body origin = z=0.90 world
             quat: 90° around Z so body faces +Y, arms extend ±X
             Arm shoulder sockets: z=0.90+0.698=1.598 world (~1.6m)
             ================================================================ -->
        <body name="openarm_body_link0" pos="0 0 0.60" quat="0.7071068 0 0 0.7071068">
          <inertial pos="0.0 0.0 0.0" quat="1.0 0.0 0.0 0.0" mass="13.89"
                    diaginertia="1.653 1.653 0.051"/>
          <geom type="mesh" mesh="body_col" class="collision"/>
          <geom type="mesh" material="matte_black"  mesh="body_v0" class="visual"/>
          <geom type="mesh" material="metal_silver" mesh="body_v1" class="visual"/>
          <geom type="mesh" material="matte_black"  mesh="body_v2" class="visual"/>
          <geom type="mesh" material="matte_black"  mesh="body_v3" class="visual"/>
          <geom type="mesh" material="metal_silver" mesh="body_v4" class="visual"/>
          <geom type="mesh" material="matte_black"  mesh="body_v5" class="visual"/>

          <!-- HEAD: cancel parent 90°Z so head faces +Y, joints work in world frame -->
          <body name="head_pan_link" pos="0 0 0.76" quat="0.7071068 0 0 -0.7071068">
            <joint name="head_pan" class="head" axis="0 0 1" range="-1.57 1.57"/>
            <geom type="cylinder" size="0.042 0.040" material="dark_mat" mass="0.2"/>
            <body name="head" pos="0 0 0.06">
              <joint name="head_tilt" class="head" axis="0 1 0" range="-0.52 0.52"/>
              <geom name="head_geom" type="box" size="0.11 0.09 0.12" material="body_mat" mass="1.5"/>
              <geom name="face_plate" type="box" size="0.09 0.01 0.07"
                    pos="0 0.09 0.01" rgba="0.2 0.2 0.2 1" mass="0"/>
              <site name="cam_rgb"   pos="0 0.10  0.02" size="0.018" rgba="0.1 0.5 0.9 1"/>
              <site name="cam_depth" pos="0 0.10 -0.02" size="0.018" rgba="0.9 0.3 0.1 1"/>
            </body>
          </body>

