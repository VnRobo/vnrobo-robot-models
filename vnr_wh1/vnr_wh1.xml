<!-- VNR-WH1 — VnRobo Wheeled Humanoid 1
     Version: 0.5.0-bimanual
     DOF: 21 (3 wheels + 2 head + 7L + 7R + 2 grippers)
     v0.5: OpenArm bimanual body_link0 + both arms verbatim from enactic/openarm_mujoco
       - Slim vertical pole replaces crude capsule torso/chest
       - body_link0 = shared back-plate connecting both arms (exact bimanual meshes)
       - Arm chains verbatim from openarm_bimanual.xml (inertials, limits, quats)
       - body_link0 mounted with 90°Z rotation so arms extend ±X (left/right)
-->
<mujoco model="vnr_wh1">

  <compiler angle="radian" meshdir="assets/openarm" inertiafromgeom="auto"/>

  <visual>
    <global offwidth="1920" offheight="1080"/>
  </visual>

  <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>

  <!-- =============================================================== -->
  <!-- DEFAULTS                                                         -->
  <!-- =============================================================== -->
  <default>
    <geom condim="4" friction="1.0 0.005 0.0001" solimp="0.9 0.95 0.001" solref="0.02 1"/>

    <default class="wheel">
      <joint type="hinge" damping="0.3" armature="0.005" limited="false"/>
      <velocity gear="1" ctrlrange="-15 15"/>
    </default>

    <default class="head">
      <joint type="hinge" damping="0.5" armature="0.005" limited="true"/>
      <position kp="50" kv="5"/>
    </default>

    <!-- OpenArm joint physics from bimanual.xml -->
    <default class="motor_DM8009">
      <joint frictionloss="0.1" damping="0.4" limited="true" type="hinge"/>
    </default>
    <default class="motor_DM4340">
      <joint frictionloss="0.1" damping="0.4" limited="true" type="hinge"/>
    </default>
    <default class="motor_DM4310">
      <joint frictionloss="0.1" damping="0.4" limited="true" type="hinge"/>
    </default>
    <default class="motor_finger">
      <joint limited="true" type="slide" damping="2" stiffness="0.5"/>
    </default>

    <!-- Position actuator classes for arm joints -->
    <default class="arm_DM8009">
      <position kp="120" kv="12" forcelimited="true" forcerange="-40 40"/>
    </default>
    <default class="arm_DM4340">
      <position kp="80" kv="8" forcelimited="true" forcerange="-27 27"/>
    </default>
    <default class="arm_DM4310">
      <position kp="50" kv="5" forcelimited="true" forcerange="-7 7"/>
    </default>
    <default class="arm_finger">
      <position kp="100" kv="5" ctrlrange="0 0.044" forcelimited="true" forcerange="-333 333"/>
    </default>

    <!-- Geom display classes (collision disabled for stability) -->
    <default class="visual">
      <geom contype="0" conaffinity="0" group="2" density="0"/>
    </default>
    <default class="collision">
      <geom contype="0" conaffinity="0" group="3" density="0"/>
    </default>
  </default>

  <!-- =============================================================== -->
  <!-- ASSETS                                                           -->
  <!-- =============================================================== -->
  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.8 0.8 0.8" rgb2="0.6 0.6 0.6"
             width="512" height="512"/>
    <material name="floor_mat"       texture="grid" texrepeat="4 4" reflectance="0.2"/>
    <material name="dark_mat"        rgba="0.15 0.15 0.15 1"/>
    <material name="body_mat"        rgba="0.95 0.62 0.10 1"/>
    <material name="matte_black"     rgba="0.247 0.247 0.247 1" reflectance="0.05" shininess="0.5"/>
    <material name="metal_silver"    rgba="0.796 0.796 0.796 1" reflectance="1.0"  shininess="1.0"/>
    <material name="default_material" rgba="0.7 0.7 0.7 1"/>

    <!-- body_link0 back-plate (6 visual parts + 1 collision) -->
    <mesh name="body_col"  file="collision/body/body_link0.stl" scale="0.001 0.001 0.001"/>
    <mesh name="body_v0"   file="visual/body/body_link0_0.obj"  scale="0.001 0.001 0.001"/>
    <mesh name="body_v1"   file="visual/body/body_link0_1.obj"  scale="0.001 0.001 0.001"/>
