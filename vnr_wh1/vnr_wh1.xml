    <mesh name="link7_v1_l" file="visual/arm/link7_1.obj" scale="0.001 -0.001 0.001"/>
    <mesh name="hand_v0"   file="visual/gripper/hand_0.obj"    scale="0.001 0.001 0.001"/>
    <mesh name="hand_v1"   file="visual/gripper/hand_1.obj"    scale="0.001 0.001 0.001"/>
    <mesh name="finger_v0" file="visual/gripper/finger_0.obj"  scale="0.001  0.001 0.001"/>
    <mesh name="finger_v1" file="visual/gripper/finger_1.obj"  scale="0.001  0.001 0.001"/>
    <mesh name="finger_v0_l" file="visual/gripper/finger_0.obj" scale="0.001 -0.001 0.001"/>
