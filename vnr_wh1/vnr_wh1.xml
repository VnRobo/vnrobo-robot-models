    <mesh name="link5_v1"  file="visual/arm/link5_1.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link5_v2"  file="visual/arm/link5_2.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link6_v0"  file="visual/arm/link6_0.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link6_v1"  file="visual/arm/link6_1.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link6_v0_l" file="visual/arm/link6_0.obj" scale="0.001 -0.001 0.001"/>
