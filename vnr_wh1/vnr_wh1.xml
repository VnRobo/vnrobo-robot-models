<!-- VNR-WH1 — VnRobo Wheeled Humanoid 1
     Version: 0.2.0-primitive
     DOF: 18 controllable (3 wheels + 2 head + 6L arm + 6R arm + 2 grippers)
     Mass: ~58 kg  |  Height: ~1.35 m
     v0.2 changes:
       - Wider shoulders (±0.24 m), upper arm 0.30 m, forearm 0.28 m
       - Wheel geom zaxis matches each joint spin axis
       - QDD-style dark cylindrical motor housings at all 6 arm joints
       - Parallel-jaw gripper (flat box plates) replacing finger capsules
       - Head gap fixed (head_pan_link z=0.34)
       - Hub accent rings on wheels
-->
<mujoco model="vnr_wh1">

  <compiler angle="radian" inertiafromgeom="auto"/>

  <visual>
    <global offwidth="1920" offheight="1080"/>
  </visual>

  <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>

  <!-- =============================================================== -->
  <!-- DEFAULTS                                                         -->
  <!-- =============================================================== -->
  <default>
    <geom condim="4" friction="1.0 0.005 0.0001" solimp="0.9 0.95 0.001" solref="0.02 1"/>

    <default class="arm">
      <joint type="hinge" damping="1.5" armature="0.01" limited="true"/>
      <position kp="100" kv="10"/>
    </default>

    <default class="wheel">
      <joint type="hinge" damping="0.3" armature="0.005" limited="false"/>
      <velocity gear="1" ctrlrange="-15 15"/>
    </default>

    <default class="head">
      <joint type="hinge" damping="0.5" armature="0.005" limited="true"/>
      <position kp="50" kv="5"/>
    </default>

    <default class="gripper">
      <joint type="slide" damping="10" armature="0.002" limited="true" range="0 0.045"/>
      <position kp="300" kv="20" ctrlrange="0 0.045"/>
    </default>
  </default>

  <!-- =============================================================== -->
  <!-- ASSETS                                                           -->
  <!-- =============================================================== -->
  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.8 0.8 0.8" rgb2="0.6 0.6 0.6"
             width="512" height="512"/>
    <material name="floor_mat" texture="grid" texrepeat="4 4" reflectance="0.2"/>
    <material name="body_mat" rgba="0.95 0.62 0.10 1"/>   <!-- VnRobo amber -->
    <material name="dark_mat" rgba="0.15 0.15 0.15 1"/>   <!-- chassis / motor housing -->
    <material name="grey_mat" rgba="0.78 0.78 0.80 1"/>   <!-- arm links aluminium -->
  </asset>

  <!-- =============================================================== -->
  <!-- WORLD                                                            -->
  <!-- =============================================================== -->
  <worldbody>
    <light name="sky"  pos="0 0 5"   dir="0 0 -1"    diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" castshadow="false"/>
    <light name="fill" pos="2 -2 3"  dir="-1 1 -1"   diffuse="0.3 0.3 0.4" specular="0 0 0"       castshadow="false"/>
    <geom name="floor" type="plane" size="8 8 0.1" material="floor_mat" condim="3"/>

    <!-- ======================== BASE PLATFORM ======================== -->
    <body name="base" pos="0 0 0.20">
      <freejoint name="root"/>
      <geom name="base_geom" type="cylinder" size="0.28 0.10" material="dark_mat" mass="22"/>
      <site name="base_front" pos="0 0.26 0.11" size="0.025" rgba="0.9 0.2 0.2 1"/>
      <site name="imu" pos="0 0 0" size="0.01"/>

      <!-- ==================== WHEELS (3× omni) ==================== -->
      <!-- Front wheel — spins around X -->
      <body name="wheel_f" pos="0 0.22 -0.12">
        <joint name="wheel_f" class="wheel" axis="1 0 0"/>
        <geom name="wheel_f_geom" type="cylinder" size="0.080 0.040" zaxis="1 0 0"
              material="dark_mat" mass="0.8" friction="2 0.01 0.001"/>
        <!-- Hub accent (amber ring, inset 1 mm from tire face) -->
        <geom type="cylinder" size="0.055 0.039" zaxis="1 0 0"
              material="body_mat" mass="0"/>
      </body>

      <!-- Back-left — spins around (-0.5, 0.866, 0) -->
      <body name="wheel_bl" pos="-0.19 -0.11 -0.12">
        <joint name="wheel_bl" class="wheel" axis="-0.5 0.866 0"/>
        <geom name="wheel_bl_geom" type="cylinder" size="0.080 0.040" zaxis="-0.5 0.866 0"
              material="dark_mat" mass="0.8" friction="2 0.01 0.001"/>
        <geom type="cylinder" size="0.055 0.039" zaxis="-0.5 0.866 0"
              material="body_mat" mass="0"/>
      </body>

      <!-- Back-right — spins around (0.5, 0.866, 0) -->
      <body name="wheel_br" pos="0.19 -0.11 -0.12">
        <joint name="wheel_br" class="wheel" axis="0.5 0.866 0"/>
        <geom name="wheel_br_geom" type="cylinder" size="0.080 0.040" zaxis="0.5 0.866 0"
              material="dark_mat" mass="0.8" friction="2 0.01 0.001"/>
        <geom type="cylinder" size="0.055 0.039" zaxis="0.5 0.866 0"
              material="body_mat" mass="0"/>
      </body>

      <!-- ==================== TORSO ==================== -->
      <body name="torso" pos="0 0 0.24">
        <geom name="torso_geom" type="capsule" fromto="0 0 0 0 0 0.48"
              size="0.12" material="body_mat" mass="14"/>

        <!-- ==================== CHEST ==================== -->
        <body name="chest" pos="0 0 0.50">
          <geom name="chest_geom" type="capsule" fromto="0 0 0 0 0 0.32"
                size="0.13" material="body_mat" mass="8"/>
          <geom name="spine_detail" type="box" size="0.04 0.01 0.14"
                pos="0 -0.13 0.12" rgba="0.3 0.3 0.3 1" mass="0"/>

          <!-- ==================== HEAD ==================== -->
          <!-- Chest top is at z=0.32; head_pan_link at z=0.34 (2 mm neck gap) -->
          <body name="head_pan_link" pos="0 0 0.34">
            <joint name="head_pan" class="head" axis="0 0 1" range="-1.57 1.57"/>
            <!-- Pan motor housing (Z-axis cylinder = neck turret) -->
            <geom type="cylinder" size="0.042 0.040" material="dark_mat" mass="0.2"/>

            <body name="head" pos="0 0 0.06">
              <joint name="head_tilt" class="head" axis="0 1 0" range="-0.52 0.52"/>
              <geom name="head_geom" type="box" size="0.11 0.09 0.12"
                    material="body_mat" mass="1.5"/>
              <geom name="face_plate" type="box" size="0.09 0.01 0.07"
                    pos="0 0.09 0.01" rgba="0.2 0.2 0.2 1" mass="0"/>
              <site name="cam_rgb"   pos="0 0.10  0.02" size="0.018" rgba="0.1 0.5 0.9 1"/>
              <site name="cam_depth" pos="0 0.10 -0.02" size="0.018" rgba="0.9 0.3 0.1 1"/>
            </body>
          </body>

          <!-- ========================= LEFT ARM ========================= -->
          <!-- Shoulder at x=-0.24 (Panda-like width) -->
          <body name="l_shoulder" pos="-0.24 0 0.24">
            <joint name="l_sp" class="arm" axis="0 1 0" range="-3.14 1.57"/>
            <!-- Shoulder pitch QDD housing (Y-axis) -->
            <geom type="cylinder" size="0.048 0.026" zaxis="0 1 0"
                  material="dark_mat" mass="0.4"/>

            <!-- Upper arm — shoulder roll -->
            <body name="l_uarm" pos="0 0 -0.06">
              <joint name="l_sr" class="arm" axis="1 0 0" range="-1.57 1.57"/>
              <!-- Shoulder roll housing (X-axis) at joint origin -->
              <geom type="cylinder" size="0.044 0.024" zaxis="1 0 0"
                    material="dark_mat" mass="0"/>
              <!-- Upper arm link: 0.30 m -->
              <geom name="l_uarm_geom" type="capsule" fromto="0 0 0 0 0 -0.30"
                    size="0.036" material="grey_mat" mass="1.4"/>

              <!-- Elbow yaw (twist) -->
              <body name="l_elbow_link" pos="0 0 -0.30">
                <joint name="l_sy" class="arm" axis="0 0 1" range="-1.57 1.57"/>
                <!-- Elbow yaw housing (Z-axis, cylinder default) -->
                <geom type="cylinder" size="0.038 0.022"
                      material="dark_mat" mass="0.15"/>

                <!-- Forearm — elbow pitch -->
                <body name="l_farm" pos="0 0 -0.02">
                  <joint name="l_ep" class="arm" axis="0 1 0" range="-2.36 0"/>
                  <!-- Elbow pitch housing (Y-axis) -->
                  <geom type="cylinder" size="0.038 0.022" zaxis="0 1 0"
                        material="dark_mat" mass="0"/>
                  <!-- Forearm link: 0.28 m -->
                  <geom name="l_farm_geom" type="capsule" fromto="0 0 0 0 0 -0.28"
                        size="0.030" material="grey_mat" mass="1.1"/>

                  <!-- Wrist pitch -->
                  <body name="l_wrist_link" pos="0 0 -0.28">
                    <joint name="l_wp" class="arm" axis="0 1 0" range="-1.57 1.57"/>
                    <!-- Wrist pitch housing (Y-axis) -->
                    <geom type="cylinder" size="0.034 0.020" zaxis="0 1 0"
                          material="dark_mat" mass="0.10"/>

                    <!-- Hand — wrist roll -->
                    <body name="l_hand" pos="0 0 -0.02">
                      <joint name="l_wr" class="arm" axis="0 0 1" range="-1.57 1.57"/>
                      <!-- Wrist roll housing (Z-axis) -->
                      <geom type="cylinder" size="0.032 0.018"
                            material="dark_mat" mass="0"/>
                      <!-- Palm block -->
                      <geom name="l_hand_geom" type="box" size="0.034 0.022 0.048"
                            pos="0 0 -0.032" material="grey_mat" mass="0.4"/>
                      <site name="l_tcp" pos="0 0 -0.11" size="0.01" rgba="0 1 0 1"/>

                      <!-- ===== Left parallel-jaw gripper ===== -->
                      <!-- Left jaw slides in -X to open -->
                      <body name="l_fl" pos="-0.025 0 -0.065">
                        <joint name="l_gl" class="gripper" axis="1 0 0"/>
                        <!-- Jaw plate (dark) -->
                        <geom type="box" size="0.009 0.020 0.028"
                              pos="-0.005 0 -0.016" material="dark_mat" mass="0.07"/>
                        <!-- Finger-pad tip (amber) -->
                        <geom type="box" size="0.006 0.016 0.006"
                              pos="-0.002 0 -0.046" material="body_mat" mass="0.01"/>
                      </body>
                      <!-- Right jaw slides in +X to open -->
                      <body name="l_fr" pos="0.025 0 -0.065">
                        <joint name="l_gr" class="gripper" axis="-1 0 0"/>
                        <geom type="box" size="0.009 0.020 0.028"
                              pos="0.005 0 -0.016" material="dark_mat" mass="0.07"/>
                        <geom type="box" size="0.006 0.016 0.006"
                              pos="0.002 0 -0.046" material="body_mat" mass="0.01"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>

          <!-- ========================= RIGHT ARM (mirror) ========================= -->
          <body name="r_shoulder" pos="0.24 0 0.24">
            <joint name="r_sp" class="arm" axis="0 1 0" range="-3.14 1.57"/>
            <geom type="cylinder" size="0.048 0.026" zaxis="0 1 0"
                  material="dark_mat" mass="0.4"/>

            <body name="r_uarm" pos="0 0 -0.06">
              <joint name="r_sr" class="arm" axis="1 0 0" range="-1.57 1.57"/>
              <geom type="cylinder" size="0.044 0.024" zaxis="1 0 0"
                    material="dark_mat" mass="0"/>
              <geom name="r_uarm_geom" type="capsule" fromto="0 0 0 0 0 -0.30"
                    size="0.036" material="grey_mat" mass="1.4"/>

              <body name="r_elbow_link" pos="0 0 -0.30">
                <joint name="r_sy" class="arm" axis="0 0 1" range="-1.57 1.57"/>
                <geom type="cylinder" size="0.038 0.022"
                      material="dark_mat" mass="0.15"/>

                <body name="r_farm" pos="0 0 -0.02">
                  <joint name="r_ep" class="arm" axis="0 1 0" range="0 2.36"/>
                  <geom type="cylinder" size="0.038 0.022" zaxis="0 1 0"
                        material="dark_mat" mass="0"/>
                  <geom name="r_farm_geom" type="capsule" fromto="0 0 0 0 0 -0.28"
                        size="0.030" material="grey_mat" mass="1.1"/>

                  <body name="r_wrist_link" pos="0 0 -0.28">
                    <joint name="r_wp" class="arm" axis="0 1 0" range="-1.57 1.57"/>
                    <geom type="cylinder" size="0.034 0.020" zaxis="0 1 0"
                          material="dark_mat" mass="0.10"/>

                    <body name="r_hand" pos="0 0 -0.02">
                      <joint name="r_wr" class="arm" axis="0 0 1" range="-1.57 1.57"/>
                      <geom type="cylinder" size="0.032 0.018"
                            material="dark_mat" mass="0"/>
                      <geom name="r_hand_geom" type="box" size="0.034 0.022 0.048"
                            pos="0 0 -0.032" material="grey_mat" mass="0.4"/>
                      <site name="r_tcp" pos="0 0 -0.11" size="0.01" rgba="0 1 0 1"/>

                      <!-- ===== Right parallel-jaw gripper ===== -->
                      <body name="r_fl" pos="-0.025 0 -0.065">
                        <joint name="r_gl" class="gripper" axis="1 0 0"/>
                        <geom type="box" size="0.009 0.020 0.028"
                              pos="-0.005 0 -0.016" material="dark_mat" mass="0.07"/>
                        <geom type="box" size="0.006 0.016 0.006"
                              pos="-0.002 0 -0.046" material="body_mat" mass="0.01"/>
                      </body>
                      <body name="r_fr" pos="0.025 0 -0.065">
                        <joint name="r_gr" class="gripper" axis="-1 0 0"/>
                        <geom type="box" size="0.009 0.020 0.028"
                              pos="0.005 0 -0.016" material="dark_mat" mass="0.07"/>
                        <geom type="box" size="0.006 0.016 0.006"
                              pos="0.002 0 -0.046" material="body_mat" mass="0.01"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>

        </body> <!-- chest -->
      </body> <!-- torso -->
    </body> <!-- base -->
  </worldbody>

  <!-- =============================================================== -->
  <!-- EQUALITY CONSTRAINTS (coupled gripper fingers)                  -->
  <!-- =============================================================== -->
  <equality>
    <joint name="l_gripper_couple" joint1="l_gl" joint2="l_gr" polycoef="0 1 0 0 0"/>
    <joint name="r_gripper_couple" joint1="r_gl" joint2="r_gr" polycoef="0 1 0 0 0"/>
  </equality>

  <!-- =============================================================== -->
  <!-- ACTUATORS                                                        -->
  <!-- =============================================================== -->
  <actuator>
    <!-- WHEELS: velocity control (rad/s) -->
    <velocity name="wheel_f"  joint="wheel_f"  class="wheel"/>
    <velocity name="wheel_bl" joint="wheel_bl" class="wheel"/>
    <velocity name="wheel_br" joint="wheel_br" class="wheel"/>

    <!-- HEAD: position control (rad) -->
    <position name="head_pan"  joint="head_pan"  class="head" ctrlrange="-1.57 1.57"/>
    <position name="head_tilt" joint="head_tilt" class="head" ctrlrange="-0.52 0.52"/>

    <!-- LEFT ARM -->
    <position name="l_sp" joint="l_sp" class="arm" ctrlrange="-3.14 1.57"/>
    <position name="l_sr" joint="l_sr" class="arm" ctrlrange="-1.57 1.57"/>
    <position name="l_sy" joint="l_sy" class="arm" ctrlrange="-1.57 1.57"/>
    <position name="l_ep" joint="l_ep" class="arm" ctrlrange="-2.36 0"/>
    <position name="l_wp" joint="l_wp" class="arm" ctrlrange="-1.57 1.57"/>
    <position name="l_wr" joint="l_wr" class="arm" ctrlrange="-1.57 1.57"/>
    <position name="l_grip" joint="l_gl" class="gripper"/>

    <!-- RIGHT ARM -->
    <position name="r_sp" joint="r_sp" class="arm" ctrlrange="-3.14 1.57"/>
    <position name="r_sr" joint="r_sr" class="arm" ctrlrange="-1.57 1.57"/>
    <position name="r_sy" joint="r_sy" class="arm" ctrlrange="-1.57 1.57"/>
    <position name="r_ep" joint="r_ep" class="arm" ctrlrange="0 2.36"/>
    <position name="r_wp" joint="r_wp" class="arm" ctrlrange="-1.57 1.57"/>
    <position name="r_wr" joint="r_wr" class="arm" ctrlrange="-1.57 1.57"/>
    <position name="r_grip" joint="r_gl" class="gripper"/>
  </actuator>

  <!-- =============================================================== -->
  <!-- SENSORS                                                          -->
  <!-- =============================================================== -->
  <sensor>
    <accelerometer name="imu_accel" site="imu"/>
    <gyro          name="imu_gyro"  site="imu"/>

    <framepos    name="base_pos"    objtype="body" objname="base"/>
    <framequat   name="base_quat"   objtype="body" objname="base"/>
    <framelinvel name="base_linvel" objtype="body" objname="base"/>
    <frameangvel name="base_angvel" objtype="body" objname="base"/>

    <framepos name="l_tcp_pos" objtype="site" objname="l_tcp"/>
    <framepos name="r_tcp_pos" objtype="site" objname="r_tcp"/>

    <framepos  name="cam_rgb_pos"  objtype="site" objname="cam_rgb"/>
    <framequat name="cam_rgb_quat" objtype="site" objname="cam_rgb"/>
  </sensor>

</mujoco>
