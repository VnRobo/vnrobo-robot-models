<!-- VNR-WH1 — VnRobo Wheeled Humanoid 1
     Version: 0.3.0-primitive
     DOF: 21 controllable (3 wheels + 2 head + 7L arm + 7R arm + 2 grippers)
     Mass: ~60 kg  |  Height: ~1.35 m
     v0.3: Arms replaced with OpenArm v10 7-DOF kinematic chain
       - Exact joint offsets from enactic/openarm_description config/arm/v10/kinematics.yaml
       - Joint axes from URDF: Z-X-Z-Y-Z-X-Y (J1-J7)
       - Flat QDD disc housings at each joint (alternating orientations)
       - Capsule tube links between discs
       - Parallel-jaw gripper (flat box plates)
       - Left arm mirrors Right arm in X
-->
<mujoco model="vnr_wh1">

  <compiler angle="radian" inertiafromgeom="auto"/>

  <visual>
    <global offwidth="1920" offheight="1080"/>
  </visual>

  <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>

  <!-- =============================================================== -->
  <!-- DEFAULTS                                                         -->
  <!-- =============================================================== -->
  <default>
    <geom condim="4" friction="1.0 0.005 0.0001" solimp="0.9 0.95 0.001" solref="0.02 1"/>

    <default class="arm">
      <joint type="hinge" damping="1.5" armature="0.01" limited="true"/>
      <position kp="100" kv="10"/>
    </default>

    <default class="wheel">
      <joint type="hinge" damping="0.3" armature="0.005" limited="false"/>
      <velocity gear="1" ctrlrange="-15 15"/>
    </default>

    <default class="head">
      <joint type="hinge" damping="0.5" armature="0.005" limited="true"/>
      <position kp="50" kv="5"/>
    </default>

    <default class="gripper">
      <joint type="slide" damping="10" armature="0.002" limited="true" range="0 0.043"/>
      <position kp="300" kv="20" ctrlrange="0 0.043"/>
    </default>
  </default>

  <!-- =============================================================== -->
  <!-- ASSETS                                                           -->
  <!-- =============================================================== -->
  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.8 0.8 0.8" rgb2="0.6 0.6 0.6"
             width="512" height="512"/>
    <material name="floor_mat" texture="grid" texrepeat="4 4" reflectance="0.2"/>
    <material name="body_mat" rgba="0.95 0.62 0.10 1"/>   <!-- VnRobo amber -->
    <material name="dark_mat" rgba="0.15 0.15 0.15 1"/>   <!-- chassis / QDD disc -->
    <material name="grey_mat" rgba="0.78 0.78 0.80 1"/>   <!-- link tubes aluminium -->
  </asset>

  <!-- =============================================================== -->
  <!-- WORLD                                                            -->
  <!-- =============================================================== -->
  <worldbody>
    <light name="sky"  pos="0 0 5"  dir="0 0 -1"  diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" castshadow="false"/>
    <light name="fill" pos="2 -2 3" dir="-1 1 -1" diffuse="0.3 0.3 0.4" specular="0 0 0"       castshadow="false"/>
    <geom name="floor" type="plane" size="8 8 0.1" material="floor_mat" condim="3"/>

    <!-- ======================== BASE PLATFORM ======================== -->
    <body name="base" pos="0 0 0.20">
      <freejoint name="root"/>
      <geom name="base_geom" type="cylinder" size="0.28 0.10" material="dark_mat" mass="22"/>
      <site name="base_front" pos="0 0.26 0.11" size="0.025" rgba="0.9 0.2 0.2 1"/>
      <site name="imu" pos="0 0 0" size="0.01"/>

      <!-- ==================== WHEELS (3× omni) ==================== -->
      <body name="wheel_f" pos="0 0.22 -0.12">
        <joint name="wheel_f" class="wheel" axis="1 0 0"/>
        <geom name="wheel_f_geom" type="cylinder" size="0.080 0.040" zaxis="1 0 0"
              material="dark_mat" mass="0.8" friction="2 0.01 0.001"/>
        <geom type="cylinder" size="0.055 0.039" zaxis="1 0 0" material="body_mat" mass="0"/>
      </body>

      <body name="wheel_bl" pos="-0.19 -0.11 -0.12">
        <joint name="wheel_bl" class="wheel" axis="-0.5 0.866 0"/>
        <geom name="wheel_bl_geom" type="cylinder" size="0.080 0.040" zaxis="-0.5 0.866 0"
              material="dark_mat" mass="0.8" friction="2 0.01 0.001"/>
        <geom type="cylinder" size="0.055 0.039" zaxis="-0.5 0.866 0" material="body_mat" mass="0"/>
      </body>

      <body name="wheel_br" pos="0.19 -0.11 -0.12">
        <joint name="wheel_br" class="wheel" axis="0.5 0.866 0"/>
        <geom name="wheel_br_geom" type="cylinder" size="0.080 0.040" zaxis="0.5 0.866 0"
              material="dark_mat" mass="0.8" friction="2 0.01 0.001"/>
        <geom type="cylinder" size="0.055 0.039" zaxis="0.5 0.866 0" material="body_mat" mass="0"/>
      </body>

      <!-- ==================== TORSO ==================== -->
      <body name="torso" pos="0 0 0.24">
        <geom name="torso_geom" type="capsule" fromto="0 0 0 0 0 0.48"
              size="0.12" material="body_mat" mass="14"/>

        <!-- ==================== CHEST ==================== -->
        <body name="chest" pos="0 0 0.50">
          <geom name="chest_geom" type="capsule" fromto="0 0 0 0 0 0.32"
                size="0.13" material="body_mat" mass="8"/>
          <geom name="spine_detail" type="box" size="0.04 0.01 0.14"
                pos="0 -0.13 0.12" rgba="0.3 0.3 0.3 1" mass="0"/>

          <!-- ==================== HEAD ==================== -->
          <body name="head_pan_link" pos="0 0 0.34">
            <joint name="head_pan" class="head" axis="0 0 1" range="-1.57 1.57"/>
            <geom type="cylinder" size="0.042 0.040" material="dark_mat" mass="0.2"/>
            <body name="head" pos="0 0 0.06">
              <joint name="head_tilt" class="head" axis="0 1 0" range="-0.52 0.52"/>
              <geom name="head_geom" type="box" size="0.11 0.09 0.12"
                    material="body_mat" mass="1.5"/>
              <geom name="face_plate" type="box" size="0.09 0.01 0.07"
                    pos="0 0.09 0.01" rgba="0.2 0.2 0.2 1" mass="0"/>
              <site name="cam_rgb"   pos="0 0.10  0.02" size="0.018" rgba="0.1 0.5 0.9 1"/>
              <site name="cam_depth" pos="0 0.10 -0.02" size="0.018" rgba="0.9 0.3 0.1 1"/>
            </body>
          </body>

          <!-- =======================================================
               LEFT ARM — OpenArm v10 7-DOF
               Joint offsets from enactic/openarm_description kinematics.yaml
               Z offsets negated (arm hangs down from shoulder mount).
               X offsets kept as-is (left arm = OpenArm right convention).
               Axes: J1=Z  J2=−X  J3=Z  J4=Y  J5=Z  J6=X  J7=Y
               ======================================================= -->
          <body name="l_shoulder" pos="-0.24 0 0.24">

            <!-- J1: shoulder pan (Z) -->
            <joint name="l_j1" class="arm" axis="0 0 1" range="-2.79 2.79"/>
            <geom type="cylinder" size="0.046 0.024" material="dark_mat" mass="0.6"/>
            <!-- stub tube to J2 -->
            <geom type="capsule" fromto="0 0 0 0 0 -0.0625" size="0.020" material="grey_mat" mass="0"/>

            <!-- J2 body: x=-0.0301, z=-0.06 from J1 -->
            <body name="l_j2" pos="0 0 -0.0625">
              <!-- J2: shoulder tilt (−X) -->
              <joint name="l_j2" class="arm" axis="-1 0 0" range="-1.745 1.745"/>
              <geom type="cylinder" size="0.044 0.022" zaxis="1 0 0" material="dark_mat" mass="0.6"/>
              <!-- stub tube to J3 -->
              <geom type="capsule" fromto="0 0 0 -0.0301 0 -0.060" size="0.020" material="grey_mat" mass="0"/>

              <!-- J3 body: x=−0.0301, z=−0.06 from J2 -->
              <body name="l_j3" pos="-0.0301 0 -0.060">
                <!-- J3: shoulder twist (Z) -->
                <joint name="l_j3" class="arm" axis="0 0 1" range="-1.571 1.571"/>
                <geom type="cylinder" size="0.040 0.020" material="dark_mat" mass="0.4"/>
                <!-- stub tube to J4 -->
                <geom type="capsule" fromto="0 0 0 0.0301 0 -0.06625" size="0.020" material="grey_mat" mass="0"/>

                <!-- J4 body (elbow): x=+0.0301, y=+0.0315, z=−0.15375 from J3 -->
                <body name="l_j4" pos="0.0301 0 -0.06625">
                  <!-- J4: elbow bend (Y) — range 0..140° -->
                  <joint name="l_j4" class="arm" axis="0 1 0" range="0 2.443"/>
                  <geom type="cylinder" size="0.040 0.020" zaxis="0 1 0" material="dark_mat" mass="0.4"/>
                  <!-- upper arm tube → J5 -->
                  <geom type="capsule" fromto="0 0 0 0 0.0315 -0.15375" size="0.022" material="grey_mat" mass="0.5"/>

                  <!-- J5 body (forearm): y=+0.0315, z=−0.15375 from J4 -->
                  <body name="l_j5" pos="0 0.0315 -0.15375">
                    <!-- J5: forearm twist (Z) -->
                    <joint name="l_j5" class="arm" axis="0 0 1" range="-1.571 1.571"/>
                    <geom type="cylinder" size="0.034 0.018" material="dark_mat" mass="0.3"/>
                    <!-- elbow tube → J6 -->
                    <geom type="capsule" fromto="0 0 0 0 -0.0315 -0.0955" size="0.018" material="grey_mat" mass="0.3"/>

                    <!-- J6 body (wrist): y=−0.0315, z=−0.0955 from J5 -->
                    <body name="l_j6" pos="0 -0.0315 -0.0955">
                      <!-- J6: wrist pitch (X) -->
                      <joint name="l_j6" class="arm" axis="1 0 0" range="-0.785 0.785"/>
                      <geom type="cylinder" size="0.032 0.016" zaxis="1 0 0" material="dark_mat" mass="0.2"/>
                      <!-- forearm tube → J7 -->
                      <geom type="capsule" fromto="0 0 0 0.0375 0 -0.1205" size="0.016" material="grey_mat" mass="0.4"/>

                      <!-- J7 body (wrist roll): x=+0.0375, z=−0.1205 from J6 -->
                      <body name="l_j7" pos="0.0375 0 -0.1205">
                        <!-- J7: wrist roll (Y) -->
                        <joint name="l_j7" class="arm" axis="0 1 0" range="-1.571 1.571"/>
                        <geom type="cylinder" size="0.028 0.014" zaxis="0 1 0" material="dark_mat" mass="0.15"/>

                        <!-- Hand + parallel-jaw gripper -->
                        <body name="l_hand" pos="-0.0375 0 -0.020">
                          <geom name="l_hand_geom" type="box" size="0.032 0.020 0.040"
                                pos="0 0 -0.028" material="grey_mat" mass="0.3"/>
                          <site name="l_tcp" pos="0 0 -0.095" size="0.01" rgba="0 1 0 1"/>

                          <body name="l_fl" pos="-0.022 0 -0.056">
                            <joint name="l_gl" class="gripper" axis="1 0 0"/>
                            <geom type="box" size="0.008 0.018 0.026" pos="-0.004 0 -0.014"
                                  material="dark_mat" mass="0.06"/>
                            <geom type="box" size="0.005 0.014 0.005" pos="-0.002 0 -0.042"
                                  material="body_mat" mass="0.01"/>
                          </body>
                          <body name="l_fr" pos="0.022 0 -0.056">
                            <joint name="l_gr" class="gripper" axis="-1 0 0"/>
                            <geom type="box" size="0.008 0.018 0.026" pos="0.004 0 -0.014"
                                  material="dark_mat" mass="0.06"/>
                            <geom type="box" size="0.005 0.014 0.005" pos="0.002 0 -0.042"
                                  material="body_mat" mass="0.01"/>
                          </body>
                        </body>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>

          <!-- =======================================================
               RIGHT ARM — mirror of left (X offsets negated)
               Axes: J1=Z  J2=+X  J3=Z  J4=Y  J5=Z  J6=−X  J7=Y
               ======================================================= -->
          <body name="r_shoulder" pos="0.24 0 0.24">

            <joint name="r_j1" class="arm" axis="0 0 1" range="-2.79 2.79"/>
            <geom type="cylinder" size="0.046 0.024" material="dark_mat" mass="0.6"/>
            <geom type="capsule" fromto="0 0 0 0 0 -0.0625" size="0.020" material="grey_mat" mass="0"/>

            <body name="r_j2" pos="0 0 -0.0625">
              <joint name="r_j2" class="arm" axis="1 0 0" range="-1.745 1.745"/>
              <geom type="cylinder" size="0.044 0.022" zaxis="1 0 0" material="dark_mat" mass="0.6"/>
              <geom type="capsule" fromto="0 0 0 0.0301 0 -0.060" size="0.020" material="grey_mat" mass="0"/>

              <body name="r_j3" pos="0.0301 0 -0.060">
                <joint name="r_j3" class="arm" axis="0 0 1" range="-1.571 1.571"/>
                <geom type="cylinder" size="0.040 0.020" material="dark_mat" mass="0.4"/>
                <geom type="capsule" fromto="0 0 0 -0.0301 0 -0.06625" size="0.020" material="grey_mat" mass="0"/>

                <body name="r_j4" pos="-0.0301 0 -0.06625">
                  <joint name="r_j4" class="arm" axis="0 1 0" range="0 2.443"/>
                  <geom type="cylinder" size="0.040 0.020" zaxis="0 1 0" material="dark_mat" mass="0.4"/>
                  <geom type="capsule" fromto="0 0 0 0 0.0315 -0.15375" size="0.022" material="grey_mat" mass="0.5"/>

                  <body name="r_j5" pos="0 0.0315 -0.15375">
                    <joint name="r_j5" class="arm" axis="0 0 1" range="-1.571 1.571"/>
                    <geom type="cylinder" size="0.034 0.018" material="dark_mat" mass="0.3"/>
                    <geom type="capsule" fromto="0 0 0 0 -0.0315 -0.0955" size="0.018" material="grey_mat" mass="0.3"/>

                    <body name="r_j6" pos="0 -0.0315 -0.0955">
                      <joint name="r_j6" class="arm" axis="-1 0 0" range="-0.785 0.785"/>
                      <geom type="cylinder" size="0.032 0.016" zaxis="1 0 0" material="dark_mat" mass="0.2"/>
                      <geom type="capsule" fromto="0 0 0 -0.0375 0 -0.1205" size="0.016" material="grey_mat" mass="0.4"/>

                      <body name="r_j7" pos="-0.0375 0 -0.1205">
                        <joint name="r_j7" class="arm" axis="0 1 0" range="-1.571 1.571"/>
                        <geom type="cylinder" size="0.028 0.014" zaxis="0 1 0" material="dark_mat" mass="0.15"/>

                        <body name="r_hand" pos="0.0375 0 -0.020">
                          <geom name="r_hand_geom" type="box" size="0.032 0.020 0.040"
                                pos="0 0 -0.028" material="grey_mat" mass="0.3"/>
                          <site name="r_tcp" pos="0 0 -0.095" size="0.01" rgba="0 1 0 1"/>

                          <body name="r_fl" pos="-0.022 0 -0.056">
                            <joint name="r_gl" class="gripper" axis="1 0 0"/>
                            <geom type="box" size="0.008 0.018 0.026" pos="-0.004 0 -0.014"
                                  material="dark_mat" mass="0.06"/>
                            <geom type="box" size="0.005 0.014 0.005" pos="-0.002 0 -0.042"
                                  material="body_mat" mass="0.01"/>
                          </body>
                          <body name="r_fr" pos="0.022 0 -0.056">
                            <joint name="r_gr" class="gripper" axis="-1 0 0"/>
                            <geom type="box" size="0.008 0.018 0.026" pos="0.004 0 -0.014"
                                  material="dark_mat" mass="0.06"/>
                            <geom type="box" size="0.005 0.014 0.005" pos="0.002 0 -0.042"
                                  material="body_mat" mass="0.01"/>
                          </body>
                        </body>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>

        </body> <!-- chest -->
      </body> <!-- torso -->
    </body> <!-- base -->
  </worldbody>

  <!-- =============================================================== -->
  <!-- EQUALITY CONSTRAINTS                                             -->
  <!-- =============================================================== -->
  <equality>
    <joint name="l_gripper_couple" joint1="l_gl" joint2="l_gr" polycoef="0 1 0 0 0"/>
    <joint name="r_gripper_couple" joint1="r_gl" joint2="r_gr" polycoef="0 1 0 0 0"/>
  </equality>

  <!-- =============================================================== -->
  <!-- ACTUATORS                                                        -->
  <!-- =============================================================== -->
  <actuator>
    <!-- WHEELS -->
    <velocity name="wheel_f"  joint="wheel_f"  class="wheel"/>
    <velocity name="wheel_bl" joint="wheel_bl" class="wheel"/>
    <velocity name="wheel_br" joint="wheel_br" class="wheel"/>

    <!-- HEAD -->
    <position name="head_pan"  joint="head_pan"  class="head" ctrlrange="-1.57 1.57"/>
    <position name="head_tilt" joint="head_tilt" class="head" ctrlrange="-0.52 0.52"/>

    <!-- LEFT ARM — OpenArm 7-DOF -->
    <position name="l_j1" joint="l_j1" class="arm" ctrlrange="-2.79 2.79"/>
    <position name="l_j2" joint="l_j2" class="arm" ctrlrange="-1.745 1.745"/>
    <position name="l_j3" joint="l_j3" class="arm" ctrlrange="-1.571 1.571"/>
    <position name="l_j4" joint="l_j4" class="arm" ctrlrange="0 2.443"/>
    <position name="l_j5" joint="l_j5" class="arm" ctrlrange="-1.571 1.571"/>
    <position name="l_j6" joint="l_j6" class="arm" ctrlrange="-0.785 0.785"/>
    <position name="l_j7" joint="l_j7" class="arm" ctrlrange="-1.571 1.571"/>
    <position name="l_grip" joint="l_gl" class="gripper"/>

    <!-- RIGHT ARM — OpenArm 7-DOF (mirror) -->
    <position name="r_j1" joint="r_j1" class="arm" ctrlrange="-2.79 2.79"/>
    <position name="r_j2" joint="r_j2" class="arm" ctrlrange="-1.745 1.745"/>
    <position name="r_j3" joint="r_j3" class="arm" ctrlrange="-1.571 1.571"/>
    <position name="r_j4" joint="r_j4" class="arm" ctrlrange="0 2.443"/>
    <position name="r_j5" joint="r_j5" class="arm" ctrlrange="-1.571 1.571"/>
    <position name="r_j6" joint="r_j6" class="arm" ctrlrange="-0.785 0.785"/>
    <position name="r_j7" joint="r_j7" class="arm" ctrlrange="-1.571 1.571"/>
    <position name="r_grip" joint="r_gl" class="gripper"/>
  </actuator>

  <!-- =============================================================== -->
  <!-- SENSORS                                                          -->
  <!-- =============================================================== -->
  <sensor>
    <accelerometer name="imu_accel" site="imu"/>
    <gyro          name="imu_gyro"  site="imu"/>

    <framepos    name="base_pos"    objtype="body" objname="base"/>
    <framequat   name="base_quat"   objtype="body" objname="base"/>
    <framelinvel name="base_linvel" objtype="body" objname="base"/>
    <frameangvel name="base_angvel" objtype="body" objname="base"/>

    <framepos name="l_tcp_pos" objtype="site" objname="l_tcp"/>
    <framepos name="r_tcp_pos" objtype="site" objname="r_tcp"/>

    <framepos  name="cam_rgb_pos"  objtype="site" objname="cam_rgb"/>
    <framequat name="cam_rgb_quat" objtype="site" objname="cam_rgb"/>
  </sensor>

</mujoco>
