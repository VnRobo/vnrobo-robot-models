    <mesh name="link0_v1"  file="visual/arm/link0_1.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link1_v0"  file="visual/arm/link1_0.obj" scale="0.001 0.001 0.001"/>
    <mesh name="link1_v2"  file="visual/arm/link1_2.obj" scale="0.001 0.001 0.001"/>
