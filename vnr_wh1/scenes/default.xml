<!-- Default scene: VNR-WH1 on flat floor with a manipulation target object -->
<mujoco model="vnr_wh1_scene">

  <include file="../vnr_wh1.xml"/>

  <worldbody>
    <!-- A simple box for pick-and-place testing -->
    <body name="target_box" pos="0.5 0.3 0.10">
      <freejoint/>
      <geom type="box" size="0.04 0.04 0.04" mass="0.3"
            rgba="0.2 0.8 0.3 1" condim="4"/>
    </body>

    <!-- Shelf (fixed) -->
    <body name="shelf" pos="0.6 0 0.50">
      <geom type="box" size="0.20 0.15 0.02" mass="0" rgba="0.6 0.4 0.2 1"/>
      <geom type="box" size="0.02 0.15 0.25" pos="-0.20 0 -0.25" mass="0" rgba="0.6 0.4 0.2 1"/>
      <geom type="box" size="0.02 0.15 0.25" pos=" 0.20 0 -0.25" mass="0" rgba="0.6 0.4 0.2 1"/>
    </body>
  </worldbody>

</mujoco>
